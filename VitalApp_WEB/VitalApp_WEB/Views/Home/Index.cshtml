@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>VitalApp - Dashboard</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700;800&display=swap" />

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <!-- Tabler Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/tabler-icons.min.css" />

    <!-- Swiper CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

    <!-- Theme CSS (de tu carpeta assets) -->
    <link rel="stylesheet" href="~/css/theme.css" />
</head>

<body>
    <div class="d-flex">

        <!-- ===== SIDEBAR ===== -->
        <div id="miniSidebar" style="min-width:220px">
            <div class="brand-logo p-3">
                <a class="d-flex align-items-center gap-2 text-decoration-none" href="#">
                    <span class="fw-bold fs-4">VitalApp</span>
                </a>
            </div>
            <ul class="navbar-nav flex-column px-2">
                <li class="nav-item">
                    <a class="nav-link active" href="#">
                        <span class="nav-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                <path d="M5 12l-2 0l9 -9l9 9l-2 0" />
                                <path d="M5 12v7a2 2 0 0 0 2 2h10a2 2 0 0 0 2 -2v-7" />
                                <path d="M10 12h4v4h-4z" />
                            </svg>
                        </span>
                        <span class="text ms-2">Dashboard</span>
                    </a>
                </li>
                <li class="nav-item mt-2">
                    <div class="nav-heading px-3 text-muted small">Pages</div>
                    <hr class="mx-3 mb-1" />
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">
                        <span class="nav-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                <path d="M6.331 8h11.339a2 2 0 0 1 1.977 2.304l-1.255 8.152a3 3 0 0 1 -2.966 2.544h-6.852a3 3 0 0 1 -2.965 -2.544l-1.255 -8.152a2 2 0 0 1 1.977 -2.304z" />
                                <path d="M9 11v-5a3 3 0 0 1 6 0v5" />
                            </svg>
                        </span>
                        <span class="text ms-2">Ecommerce</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">
                        <span class="nav-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                <path d="M5 13a2 2 0 0 1 2 -2h10a2 2 0 0 1 2 2v6a2 2 0 0 1 -2 2h-10a2 2 0 0 1 -2 -2v-6z" />
                                <path d="M11 16a1 1 0 1 0 2 0a1 1 0 0 0 -2 0" />
                                <path d="M8 11v-4a4 4 0 1 1 8 0v4" />
                            </svg>
                        </span>
                        <span class="text ms-2">Authentication</span>
                    </a>
                </li>
            </ul>
        </div>

        <!-- ===== MAIN CONTENT ===== -->
        <div id="content" class="flex-grow-1">

            <!-- TOPBAR -->
            <div class="navbar navbar-expand-lg px-4 border-bottom">
                <div class="d-flex align-items-center gap-4 flex-grow-1">
                    <span class="fw-semibold">Dashboard</span>
                </div>
                <ul class="list-unstyled d-flex align-items-center mb-0 gap-2">
                    <li>
                        <button type="button" class="btn btn-outline-secondary btn-sm">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                <circle cx="10" cy="10" r="7" />
                                <line x1="21" y1="21" x2="15" y2="15" />
                            </svg>
                            <small class="ms-1">Buscar</small>
                        </button>
                    </li>
                    <li>
                        <a href="#" class="btn btn-ghost btn-icon rounded-circle position-relative">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                <path d="M10 5a2 2 0 1 1 4 0a7 7 0 0 1 4 6v3a4 4 0 0 0 2 3h-16a4 4 0 0 0 2 -3v-3a7 7 0 0 1 4 -6" />
                                <path d="M9 17v1a3 3 0 0 0 6 0v-1" />
                            </svg>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger mt-2 ms-n2">2</span>
                        </a>
                    </li>
                    <li class="ms-2">
                        <a href="#" class="d-flex align-items-center gap-2 text-decoration-none">
                            <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center" style="width:32px;height:32px">A</div>
                            <span class="small">Admin</span>
                        </a>
                    </li>
                </ul>
            </div>

            <!-- DASHBOARD CONTENT -->
            <div class="p-4">

                <!-- Bienvenida + Swiper -->
                <div class="row mb-4 g-4">
                    <div class="col-xl-8 col-lg-6">
                        <div class="bg-primary bg-gradient p-5 rounded-3 text-white">
                            <h1 class="fs-3">👋 Hola, Ana</h1>
                            <p class="mb-0">Bienvenida a tu dashboard. Monitorea tus ventas,</p>
                            <p>sigue tu progreso y obtén información valiosa.</p>
                            <a href="#" class="btn btn-dark">Iniciar IA</a>
                        </div>
                    </div>
                    <div class="col-xl-4 col-lg-6">
                        <div class="card h-100">
                            <div class="card-body">
                                <h5 class="mb-3">Ideas para ti</h5>
                                <div class="swiper" id="swiper-1">
                                    <div class="swiper-wrapper">
                                        <div class="swiper-slide">
                                            <h6>Crea un blog para tu producto</h6>
                                            <p class="text-muted small">Lorem Ipsum es simplemente el texto de relleno de las imprentas.</p>
                                            <a href="#" class="btn btn-outline-secondary btn-sm">Leer ahora</a>
                                        </div>
                                        <div class="swiper-slide">
                                            <h6>Mejora tu estrategia de ventas</h6>
                                            <p class="text-muted small">Lorem Ipsum es simplemente el texto de relleno de las imprentas.</p>
                                            <a href="#" class="btn btn-outline-secondary btn-sm">Leer ahora</a>
                                        </div>
                                        <div class="swiper-slide">
                                            <h6>Analiza tu competencia</h6>
                                            <p class="text-muted small">Lorem Ipsum es simplemente el texto de relleno de las imprentas.</p>
                                            <a href="#" class="btn btn-outline-secondary btn-sm">Leer ahora</a>
                                        </div>
                                    </div>
                                    <div class="swiper-pagination mt-2"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tarjetas de métricas -->
                <div class="row row-cols-1 row-cols-md-3 mb-4 g-4">
                    <div class="col">
                        <div class="card">
                            <div class="card-body d-flex flex-column gap-3">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="rounded-circle bg-warning bg-opacity-25 p-2">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                                             stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                            <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                            <path d="M6 19m-2 0a2 2 0 1 0 4 0a2 2 0 1 0 -4 0" />
                                            <path d="M17 19m-2 0a2 2 0 1 0 4 0a2 2 0 1 0 -4 0" />
                                            <path d="M17 17h-11v-14h-2" />
                                            <path d="M6 5l14 1l-1 7h-13" />
                                        </svg>
                                    </div>
                                    <span>Órdenes</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fs-3 fw-bold">5,312</span>
                                    <span class="text-success small">2.29% ↑</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="card">
                            <div class="card-body d-flex flex-column gap-3">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="rounded-circle bg-success bg-opacity-25 p-2">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                                             stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                            <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                            <path d="M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0 -18 0" />
                                            <path d="M14.8 9a2 2 0 0 0 -1.8 -1h-2a2 2 0 1 0 0 4h2a2 2 0 1 1 0 4h-2a2 2 0 0 1 -1.8 -1" />
                                            <path d="M12 7v10" />
                                        </svg>
                                    </div>
                                    <span>Ingresos</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fs-3 fw-bold">$120,000</span>
                                    <span class="text-warning small">2.19% ↑</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="card">
                            <div class="card-body d-flex flex-column gap-3">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="rounded-circle bg-info bg-opacity-25 p-2">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                                             stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                            <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                                            <path d="M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0 -18 0" />
                                            <path d="M12 10m-3 0a3 3 0 1 0 6 0a3 3 0 1 0 -6 0" />
                                            <path d="M6.168 18.849a4 4 0 0 1 3.832 -2.849h4a4 4 0 0 1 3.834 2.855" />
                                        </svg>
                                    </div>
                                    <span>Tasa de Conversión</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fs-3 fw-bold">3.5%</span>
                                    <span class="text-danger small">3.19% ↓</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tabla de órdenes -->
                <div class="row g-4 mb-4">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-header">
                                <h5 class="mb-0">Órdenes Recientes</h5>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Order ID</th>
                                            <th>Monto</th>
                                            <th>Envío</th>
                                            <th>Fecha de Entrega</th>
                                            <th>Estado</th>
                                            <th>Acciones</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>#DU005</td>
                                            <td>$150</td>
                                            <td>Estándar</td>
                                            <td>Ene 20, 2025</td>
                                            <td><span class="badge bg-info">Enviado</span></td>
                                            <td><a href="#" class="btn btn-outline-secondary btn-sm">Ver</a></td>
                                        </tr>
                                        <tr>
                                            <td>#DU004</td>
                                            <td>$200</td>
                                            <td>Express</td>
                                            <td>Ene 22, 2025</td>
                                            <td><span class="badge bg-warning text-dark">Pendiente</span></td>
                                            <td><a href="#" class="btn btn-outline-secondary btn-sm">Ver</a></td>
                                        </tr>
                                        <tr>
                                            <td>#DU003</td>
                                            <td>$300</td>
                                            <td>Nocturno</td>
                                            <td>Ene 18, 2025</td>
                                            <td><span class="badge bg-danger">Cancelado</span></td>
                                            <td><a href="#" class="btn btn-outline-secondary btn-sm">Ver</a></td>
                                        </tr>
                                        <tr>
                                            <td>#DU002</td>
                                            <td>$560</td>
                                            <td>Nocturno</td>
                                            <td>Ene 13, 2025</td>
                                            <td><span class="badge bg-success">Completado</span></td>
                                            <td><a href="#" class="btn btn-outline-secondary btn-sm">Ver</a></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tabla de productos más vendidos -->
                <div class="row g-4 mb-4">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-header">
                                <h5 class="mb-0">Productos Más Vendidos</h5>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Producto</th>
                                            <th>Ventas</th>
                                            <th>Ingresos</th>
                                            <th>Rating</th>
                                            <th>Estado</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>Transparent Sunglasses</td>
                                            <td>454</td>
                                            <td>$50,000</td>
                                            <td>⭐ 5/5</td>
                                            <td><span class="badge bg-info">En Stock</span></td>
                                        </tr>
                                        <tr>
                                            <td>Frames Still Life Glasses</td>
                                            <td>454</td>
                                            <td>$50,000</td>
                                            <td>⭐ 5/5</td>
                                            <td><span class="badge bg-info">En Stock</span></td>
                                        </tr>
                                        <tr>
                                            <td>Slightly Rounded Frame</td>
                                            <td>124</td>
                                            <td>$30,000</td>
                                            <td>⭐ 4/5</td>
                                            <td><span class="badge bg-warning text-dark">Stock Bajo</span></td>
                                        </tr>
                                        <tr>
                                            <td>Rounded Frames Glasses</td>
                                            <td>124</td>
                                            <td>$30,000</td>
                                            <td>⭐ 4.8/5</td>
                                            <td><span class="badge bg-danger">Sin Stock</span></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

            </div><!-- fin p-4 -->
        </div><!-- fin content -->
    </div><!-- fin d-flex -->
    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Swiper JS -->
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script>
        new Swiper('#swiper-1', {
        loop: true,
        pagination: { el: '.swiper-pagination', clickable: true },
        autoplay: { delay: 3000 }
        });
    </script>

</body>
</html>
