@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>VitalApp - Dashboard</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700;800&display=swap" />

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <!-- Tabler Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/tabler-icons.min.css" />

    <!-- Swiper CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

    <!-- Theme CSS -->
    <link rel="stylesheet" href="~/css/theme.css" />
</head>

<body>
    <div class="d-flex">

        <!-- ===== SIDEBAR ===== -->
        <div id="miniSidebar" style="min-width:220px; min-height:100vh; background:#f8f9fa; border-right:1px solid #dee2e6;">
            <div class="brand-logo p-3 border-bottom">
                <a class="d-flex align-items-center gap-2 text-decoration-none" href="#">
                    <span style="font-size:1.5rem;">❤️</span>
                    <span class="fw-bold fs-5 text-danger">VitalApp</span>
                </a>
            </div>
            <ul class="navbar-nav flex-column px-2 pt-2">
                <li class="nav-item">
                    <a class="nav-link active fw-semibold" href="#">
                        <i class="ti ti-layout-dashboard me-2"></i>Dashboard
                    </a>
                </li>
                <li class="nav-item mt-1">
                    <a class="nav-link" href="#">
                        <i class="ti ti-activity me-2"></i>Métricas de Salud
                    </a>
                </li>
                <li class="nav-item mt-1">
                    <a class="nav-link" href="#">
                        <i class="ti ti-history me-2"></i>Historial
                    </a>
                </li>
                <li class="nav-item mt-1">
                    <a class="nav-link" href="#">
                        <i class="ti ti-bell me-2"></i>Alertas
                    </a>
                </li>
                <li class="nav-item mt-2">
                    <div class="px-3 text-muted small">Cuenta</div>
                    <hr class="mx-3 mb-1" />
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">
                        <i class="ti ti-user me-2"></i>Perfil
                    </a>
                </li>
                <li class="nav-item mt-1">
                    <a class="nav-link" href="#">
                        <i class="ti ti-lock me-2"></i>Autenticación
                    </a>
                </li>
            </ul>
        </div>

        <!-- ===== MAIN CONTENT ===== -->
        <div id="content" class="flex-grow-1">

            <!-- TOPBAR -->
            <div class="navbar navbar-expand-lg px-4 border-bottom bg-white">
                <div class="d-flex align-items-center gap-4 flex-grow-1">
                    <span class="fw-semibold">Dashboard</span>
                </div>
                <ul class="list-unstyled d-flex align-items-center mb-0 gap-2">
                    <li>
                        <button type="button" class="btn btn-outline-secondary btn-sm">
                            <i class="ti ti-search"></i>
                            <small class="ms-1">Buscar</small>
                        </button>
                    </li>
                    <li>
                        <a href="#" class="btn btn-light btn-sm rounded-circle position-relative">
                            <i class="ti ti-bell"></i>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size:0.6rem">2</span>
                        </a>
                    </li>
                    <li class="ms-2">
                        <a href="#" class="d-flex align-items-center gap-2 text-decoration-none">
                            <div class="rounded-circle bg-danger text-white d-flex align-items-center justify-content-center fw-bold" style="width:32px;height:32px">A</div>
                            <span class="small">Ana</span>
                        </a>
                    </li>
                </ul>
            </div>

            <!-- DASHBOARD CONTENT -->
            <div class="p-4 bg-light min-vh-100">

                <!-- Bienvenida + Swiper -->
                <div class="row mb-4 g-4">
                    <div class="col-xl-8 col-lg-6">
                        <div class="p-5 rounded-3 text-white" style="background: linear-gradient(135deg, #e74c3c, #c0392b);">
                            <h1 class="fs-3">👋 Hola, Ana</h1>
                            <p class="mb-0">Bienvenida a VitalApp. Registra tus métricas diarias,</p>
                            <p>visualiza tu progreso y recibe alertas personalizadas.</p>
                            <a href="#" class="btn btn-light text-danger fw-semibold">Registrar métricas</a>
                        </div>
                    </div>
                    <div class="col-xl-4 col-lg-6">
                        <div class="card h-100 shadow-sm">
                            <div class="card-body">
                                <h5 class="mb-3">💡 Recomendaciones</h5>
                                <div class="swiper" id="swiper-1">
                                    <div class="swiper-wrapper">
                                        <div class="swiper-slide">
                                            <h6>Mantén controlada tu presión</h6>
                                            <p class="text-muted small">Tu presión estuvo elevada los últimos 3 días. Considera reducir el sodio.</p>
                                            <a href="#" class="btn btn-outline-danger btn-sm">Ver historial</a>
                                        </div>
                                        <div class="swiper-slide">
                                            <h6>Mejora tus horas de sueño</h6>
                                            <p class="text-muted small">Dormiste menos de 6 horas esta semana. Lo recomendado son 7-8 horas.</p>
                                            <a href="#" class="btn btn-outline-danger btn-sm">Ver historial</a>
                                        </div>
                                        <div class="swiper-slide">
                                            <h6>Tu glucosa está estable</h6>
                                            <p class="text-muted small">¡Excelente! Tus niveles de glucosa se mantienen dentro del rango normal.</p>
                                            <a href="#" class="btn btn-outline-success btn-sm">Ver detalle</a>
                                        </div>
                                    </div>
                                    <div class="swiper-pagination mt-2"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tarjetas de métricas de salud -->
                <div class="row row-cols-1 row-cols-md-3 mb-4 g-4">
                    <div class="col">
                        <div class="card shadow-sm">
                            <div class="card-body d-flex flex-column gap-3">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="rounded-circle bg-danger bg-opacity-10 p-2 text-danger">
                                        <i class="ti ti-scale fs-5"></i>
                                    </div>
                                    <span class="fw-semibold">Peso</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fs-3 fw-bold">68.5 kg</span>
                                    <span class="text-success small">↓ 0.5 kg esta semana</span>
                                </div>
                                <div class="progress" style="height:6px">
                                    <div class="progress-bar bg-danger" style="width:65%"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="card shadow-sm">
                            <div class="card-body d-flex flex-column gap-3">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="rounded-circle bg-warning bg-opacity-10 p-2 text-warning">
                                        <i class="ti ti-heart-rate-monitor fs-5"></i>
                                    </div>
                                    <span class="fw-semibold">Presión Arterial</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fs-3 fw-bold">120/80</span>
                                    <span class="text-success small">✓ Normal</span>
                                </div>
                                <div class="progress" style="height:6px">
                                    <div class="progress-bar bg-warning" style="width:50%"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="card shadow-sm">
                            <div class="card-body d-flex flex-column gap-3">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="rounded-circle bg-info bg-opacity-10 p-2 text-info">
                                        <i class="ti ti-droplet fs-5"></i>
                                    </div>
                                    <span class="fw-semibold">Glucosa</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fs-3 fw-bold">95 mg/dL</span>
                                    <span class="text-success small">✓ En rango</span>
                                </div>
                                <div class="progress" style="height:6px">
                                    <div class="progress-bar bg-info" style="width:45%"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="card shadow-sm">
                            <div class="card-body d-flex flex-column gap-3">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="rounded-circle bg-success bg-opacity-10 p-2 text-success">
                                        <i class="ti ti-mood-happy fs-5"></i>
                                    </div>
                                    <span class="fw-semibold">Estado de Ánimo</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fs-3 fw-bold">😊 Bien</span>
                                    <span class="text-muted small">Hoy</span>
                                </div>
                                <div class="progress" style="height:6px">
                                    <div class="progress-bar bg-success" style="width:75%"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="card shadow-sm">
                            <div class="card-body d-flex flex-column gap-3">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="rounded-circle bg-primary bg-opacity-10 p-2 text-primary">
                                        <i class="ti ti-moon fs-5"></i>
                                    </div>
                                    <span class="fw-semibold">Horas de Sueño</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fs-3 fw-bold">6.5 hrs</span>
                                    <span class="text-warning small">⚠ Bajo lo recomendado</span>
                                </div>
                                <div class="progress" style="height:6px">
                                    <div class="progress-bar bg-primary" style="width:55%"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="card shadow-sm">
                            <div class="card-body d-flex flex-column gap-3">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="rounded-circle bg-danger bg-opacity-10 p-2 text-danger">
                                        <i class="ti ti-alert-triangle fs-5"></i>
                                    </div>
                                    <span class="fw-semibold">Alertas Activas</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fs-3 fw-bold">2</span>
                                    <span class="text-danger small">Requieren atención</span>
                                </div>
                                <div class="progress" style="height:6px">
                                    <div class="progress-bar bg-danger" style="width:25%"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Historial reciente + Alertas -->
                <div class="row g-4 mb-4">
                    <div class="col-xl-8">
                        <div class="card shadow-sm">
                            <div class="card-header bg-white">
                                <h5 class="mb-0">📋 Registros Recientes</h5>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Fecha</th>
                                            <th>Peso</th>
                                            <th>Presión</th>
                                            <th>Glucosa</th>
                                            <th>Sueño</th>
                                            <th>Estado</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>Jun 05, 2026</td>
                                            <td>68.5 kg</td>
                                            <td>120/80</td>
                                            <td>95 mg/dL</td>
                                            <td>6.5 hrs</td>
                                            <td><span class="badge bg-success">Normal</span></td>
                                        </tr>
                                        <tr>
                                            <td>Jun 04, 2026</td>
                                            <td>68.7 kg</td>
                                            <td>130/85</td>
                                            <td>98 mg/dL</td>
                                            <td>5.5 hrs</td>
                                            <td><span class="badge bg-warning text-dark">Atención</span></td>
                                        </tr>
                                        <tr>
                                            <td>Jun 03, 2026</td>
                                            <td>69.0 kg</td>
                                            <td>125/82</td>
                                            <td>102 mg/dL</td>
                                            <td>7.0 hrs</td>
                                            <td><span class="badge bg-success">Normal</span></td>
                                        </tr>
                                        <tr>
                                            <td>Jun 02, 2026</td>
                                            <td>69.1 kg</td>
                                            <td>135/90</td>
                                            <td>110 mg/dL</td>
                                            <td>5.0 hrs</td>
                                            <td><span class="badge bg-danger">Alerta</span></td>
                                        </tr>
                                        <tr>
                                            <td>Jun 01, 2026</td>
                                            <td>69.0 kg</td>
                                            <td>118/78</td>
                                            <td>93 mg/dL</td>
                                            <td>8.0 hrs</td>
                                            <td><span class="badge bg-success">Normal</span></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-4">
                        <div class="card shadow-sm h-100">
                            <div class="card-header bg-white">
                                <h5 class="mb-0">🔔 Alertas Activas</h5>
                            </div>
                            <div class="card-body d-flex flex-column gap-3">
                                <div class="alert alert-warning d-flex gap-3 mb-0">
                                    <i class="ti ti-moon fs-4"></i>
                                    <div>
                                        <div class="fw-semibold">Sueño insuficiente</div>
                                        <small>Dormiste menos de 6h los últimos 2 días.</small>
                                    </div>
                                </div>
                                <div class="alert alert-danger d-flex gap-3 mb-0">
                                    <i class="ti ti-heart-rate-monitor fs-4"></i>
                                    <div>
                                        <div class="fw-semibold">Presión elevada</div>
                                        <small>Tu presión estuvo sobre 130/85 el Jun 02.</small>
                                    </div>
                                </div>
                                <div class="alert alert-success d-flex gap-3 mb-0">
                                    <i class="ti ti-droplet fs-4"></i>
                                    <div>
                                        <div class="fw-semibold">Glucosa estable</div>
                                        <small>Tus niveles se mantienen en rango normal. ✓</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div><!-- fin p-4 -->
        </div><!-- fin content -->
    </div><!-- fin d-flex -->
    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Swiper JS -->
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script>
        new Swiper('#swiper-1', {
        loop: true,
        pagination: { el: '.swiper-pagination', clickable: true },
        autoplay: { delay: 3000 }
        });
    </script>

</body>
</html>
