@{
    ViewData["Title"] = "Nueva Contraseña";
    Layout = "_AuthLayout";
}

<main class="d-flex flex-column justify-content-center vh-100">
    <section>
        <div class="container">
            <div class="row mb-8">
                <div class="col-xl-4 offset-xl-4 col-md-12 col-12">
                    <div class="text-center">
                        <div class="fs-2 fw-bold d-flex align-items-center gap-2 justify-content-center mb-6">
                            <img src="~/images/brand/logo-icon.svg" alt="VitalApp" />
                            <span>VitalApp</span>
                        </div>
                        <h1 class="mb-1">Establecer nueva contraseña</h1>
                        <p class="mb-0 text-secondary">Tu nueva contraseña debe ser diferente a las anteriores.</p>
                    </div>
                </div>
            </div>

            <div class="row justify-content-center mb-5">
                <div class="col-xl-5 col-lg-6 col-md-8 col-12">
                    <ul class="nav nav-pills nav-justified gap-2" role="tablist">
                        <li class="nav-item"><span class="nav-link bg-success-subtle text-success">1. Correo</span></li>
                        <li class="nav-item"><span class="nav-link bg-success-subtle text-success">2. Código</span></li>
                        <li class="nav-item"><span class="nav-link active">3. Nueva contraseña</span></li>
                    </ul>
                </div>
            </div>

            <div class="row justify-content-center">
                <div class="col-xl-5 col-lg-6 col-md-8 col-12">
                    <div class="card card-lg mb-6">
                        <div class="card-body p-6">
                            <form class="needs-validation" asp-controller="Home" asp-action="Index" method="get" novalidate>
                                <div class="mb-3">
                                    <label for="formResetPassword" class="form-label">
                                        Nueva contraseña
                                        <span class="text-danger">*</span>
                                    </label>
                                    <div class="password-field position-relative">
                                        <input type="password" class="form-control fakePassword" id="formResetPassword" placeholder="Ingresa tu nueva contraseña" required />
                                        <span><i class="ti ti-eye-off passwordToggler"></i></span>
                                        <div class="invalid-feedback">Por favor ingresa una contraseña.</div>
                                    </div>
                                    <div class="form-text">Mínimo 8 caracteres, debe incluir mayúsculas, minúsculas y números.</div>
                                </div>
                                <div class="mb-3">
                                    <label for="formResetConfirmPassword" class="form-label">
                                        Confirmar contraseña
                                        <span class="text-danger">*</span>
                                    </label>
                                    <div class="password-field position-relative">
                                        <input type="password" class="form-control fakePassword" id="formResetConfirmPassword" placeholder="Repite tu nueva contraseña" required />
                                        <span><i class="ti ti-eye-off passwordToggler"></i></span>
                                        <div class="invalid-feedback">Por favor confirma tu contraseña.</div>
                                    </div>
                                </div>

                                <div class="d-grid mb-4">
                                    <button class="btn btn-primary" type="submit">Restablecer contraseña</button>
                                </div>
                                <div class="text-center">
                                    <a asp-action="Paso2">
                                        <span>Volver atrás</span>
                                    </a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

</main>

@section Scripts {
    <script src="~/js/password.js" asp-append-version="true"></script>
}
