@{
    ViewData["Title"] = "Recuperar Contraseña";
    Layout = "_AuthLayout";
}

<main class="d-flex flex-column justify-content-center vh-100">
    <section>
        <div class="container">
            <div class="row mb-8">
                <div class="col-xl-4 offset-xl-4 col-md-12 col-12">
                    <div class="text-center">
                        <div class="fs-2 fw-bold d-flex align-items-center gap-2 justify-content-center mb-6">
                            <img src="~/images/brand/logo-icon.svg" alt="VitalApp" />
                            <span>VitalApp</span>
                        </div>
                        <h1 class="mb-1">Recuperar Contraseña</h1>
                        <p class="mb-0 text-secondary">No te preocupes, te enviaremos las instrucciones para recuperarla.</p>
                    </div>
                </div>
            </div>

            <div class="row justify-content-center mb-5">
                <div class="col-xl-5 col-lg-6 col-md-8 col-12">
                    <ul class="nav nav-pills nav-justified gap-2" role="tablist">
                        <li class="nav-item"><span class="nav-link active">1. Correo</span></li>
                        <li class="nav-item"><span class="nav-link disabled bg-light-subtle text-secondary">2. Código</span></li>
                        <li class="nav-item"><span class="nav-link disabled bg-light-subtle text-secondary">3. Nueva contraseña</span></li>
                    </ul>
                </div>
            </div>

            <div class="row justify-content-center">
                <div class="col-xl-5 col-lg-6 col-md-8 col-12">
                    <div class="card card-lg mb-6">
                        <div class="card-body p-6">
                            <form class="needs-validation mb-5" asp-action="Paso2" method="get" novalidate>
                                <div class="mb-3">
                                    <label for="forgetEmailInput" class="form-label">
                                        Correo electrónico
                                        <span class="text-danger">*</span>
                                    </label>
                                    <input type="email" class="form-control" id="forgetEmailInput" placeholder="Ingresa tu correo" required />
                                    <div class="invalid-feedback">Por favor ingresa un correo válido.</div>
                                    <div class="form-text">Te enviaremos un código de verificación a este correo.</div>
                                </div>
                                <div class="d-grid">
                                    <button class="btn btn-primary" type="submit">Enviar código</button>
                                </div>
                            </form>
                            <div class="text-center">
                                <a asp-controller="Home" asp-action="Index">
                                    <span>Volver al inicio</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

</main>
